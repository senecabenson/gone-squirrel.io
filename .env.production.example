# Production env for Hostinger VPS deploy. Copy to .env.production on the
# VPS and fill in real secrets. NEVER commit .env.production.

# --- Postgres (in-stack docker compose service "db") ---
POSTGRES_USER=gonesquirrel
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=gonesquirrel

# Application reads this; "db" resolves to the postgres container in the
# docker compose network.
DATABASE_URL=postgresql://gonesquirrel:replace-with-strong-password@db:5432/gonesquirrel

# --- NextAuth ---
# Generate with: openssl rand -base64 48
NEXTAUTH_SECRET=replace-with-openssl-rand
NEXTAUTH_URL=https://gonesquirrel.nilegrowthworks.com
NEXT_PUBLIC_APP_URL=https://gonesquirrel.nilegrowthworks.com
NEXT_PUBLIC_SITE_URL=https://gonesquirrel.nilegrowthworks.com

# OSS-only build — keep false.
NEXT_PUBLIC_ENABLE_SAAS_FEATURES=false

# --- Optional ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
